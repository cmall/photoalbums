# Absolute path to your photo library (root + one level of subfolders only)
PHOTO_LIBRARY_ROOT=/absolute/path/to/your/photos

# --- Environment files ---
# `.env` — local development (`npm run dev`)
# `.env.production` — production build & server (`npm run build`, `npm start`)
# Copy `.env.production.example` → `.env.production` for deploy settings.
# Later files override earlier ones (.env.production overrides .env in production).

# Optional: app data directory (SQLite + cache). Overrides defaults under server/data and server/.photo-cache.
# ALBUMS_DB_PATH=/Users/cm/AlbumData/scanned.sqlite
# PHOTO_CACHE_DIR=/Users/cm/AlbumData/Scanned/Cache

# Optional: allow "Open in Photoshop" in the UI (API runs open/Photoshop on the server machine). macOS: optional PHOTOSHOP_APP_NAME (default Adobe Photoshop 2025). Windows: set PHOTOSHOP_WIN_EXE to Photoshop.exe.
# ENABLE_OPEN_IN_PHOTOSHOP=1

# Optional: password for the web UI (when set, login is required). Session lasts 30 days.
# APP_PASSWORD=your-secret-password
# Set when serving over HTTPS (e.g. behind Cloudflare Tunnel):
# APP_SECURE_COOKIES=1

# Server bind (optional)
# PORT=8787
# HOST=0.0.0.0
