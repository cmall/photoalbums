# Production settings — copy to `.env.production` at the repo root.
# Used when you run `npm run build` or `npm start` (NODE_ENV=production).
# Values here override the same keys in `.env`.

PHOTO_LIBRARY_ROOT=/absolute/path/to/your/photos

# App data — SQLite catalog + thumbnail/web cache (use absolute paths for launchd)
ALBUMS_DB_PATH=/Users/cm/AlbumData/scanned.sqlite
PHOTO_CACHE_DIR=/Users/cm/AlbumData/Scanned/Cache

# APP_PASSWORD=your-production-password
# APP_SECURE_COOKIES=1

# PORT=8787
# HOST=0.0.0.0
